// 斐波那契数列示例
// 展示函数定义、递归和循环

function fibonacci(n: number): number {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

// 计算前 10 个斐波那契数
let result: number = 0;
for (let i: number = 0; i < 10; i = i + 1) {
    result = fibonacci(i);
    console.log("fibonacci() = "); // 简化：暂不支持模板字符串
}
